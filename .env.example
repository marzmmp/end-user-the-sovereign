# End-User Sovereign — Environment Variables
# Copy this to .env and fill in your values, OR use the Setup Page.

BUSINESS_NAME=My Business

# ── Inference provider — choose ONE ─────────────────────────────────────────
INFERENCE_PROVIDER=openai          # openai | nvidia_nim | ollama
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
NVIDIA_NIM_API_KEY=nvapi-...
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Search tools ─────────────────────────────────────────────────────────────
BRAVE_API_KEY=BSA...
TAVILY_API_KEY=tvly-...

# ── Voice — choose ONE ───────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs            # elevenlabs | kokoro
ELEVENLABS_API_KEY=sk_...
KOKORO_HOST=http://kokoro:7960     # only used when TTS_PROVIDER=kokoro

VAULT_PASSWORD_HASH=               # set by setup page
SOVEREIGN_TOKEN=YAHUAH-3565        # fleet auth — do not change
